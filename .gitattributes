# Handle line endings automatically
* text=auto

# Force LF for specific file types
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.stl binary
